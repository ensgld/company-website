# Ortam değişkenleri şablonu — bu dosya git'e commit EDİLİR.
# Kopyalayıp `.env` oluşturun ve gerçek değerleri girin: cp .env.example .env
# Vercel'de: Project Settings > Environment Variables altına aynı değişkenleri ekleyin.

# Web3Forms iletişim formu erişim anahtarı (https://web3forms.com)
VITE_WEB3FORMS_KEY=

# İletişim bilgileri (tek kaynak)
VITE_PHONE=+905000000000
VITE_PHONE_DISPLAY=0500 000 00 00
VITE_WHATSAPP_NUMBER=905000000000
VITE_EMAIL=ornek@ornek.com
VITE_INSTAGRAM_URL=https://www.instagram.com/kullaniciadi/

# Kanonik URL üretimi için site kök adresi
VITE_SITE_URL=https://example.com

# Google Maps sorgusu (arama + embed URL'leri bundan türetilir)
VITE_MAPS_QUERY=
